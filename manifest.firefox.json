{
  "manifest_version": 3,
  "name": "TrollGuard",
  "version": "0.1.0",
  "description": "Locally analyze visible comments for potentially problematic content. Results are suggestions, not judgments.",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "TrollGuard",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "type": "module"
    }
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "trollguard@example.com",
      "strict_min_version": "112.0"
    }
  }
}
